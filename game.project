[bootstrap]
main_collection = /main/main.collectionc
render = /builtins/render/default.renderc

[script]
shared_state = 1

[display]
width = 480
height = 270
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01
debug = 0
use_fixed_timestep = 1

[html5]
scale_mode = stretch

[project]
title = Mountain Climber

[graphics]
default_texture_min_filter = linear_mipmap_nearest
default_texture_mag_filter = nearest

