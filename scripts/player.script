	if upgrades.parts.robot_brain then
		return "upgraded_brain"
	elseif upgrades.parts.robot_torso then
		return "upgraded_torso"
	elseif upgrades.parts.robot_eyes then
		return "upgraded_eyes"
	elseif upgrades.parts.robot_legs then
		return "upgraded_legs"
	elseif upgrades.parts.robot_arms then
		return "upgraded_arms"
	else
		return "no_upgrades"
	end
end
]]

go.property("controller", hash("idle"))
go.property("current_level", 1)

function init(self)
	-- Add initialization code here
	-- Learn more: https://defold.com/manuals/script/
	-- Remove this function if not needed

	-- this lets us handle input in this script
	msg.post(".", "acquire_input_focus")
	-- initial player velocity
	self.velocity = vmath.vector3(0, 0, 0)
	-- support variable to keep track of collisions and separation
	self.correction = vmath.vector3()
	-- if the player stands on ground or not
	self.ground_contact = true
	-- safe pos to return to
	self.safe_pos = go.get_position()
	-- tracks double jump
	self.jump_count = 0  
	-- if the player touches wall or not
	self.wall_contact = false
	-- -1 = wall on left, 1 = wall on right
	self.wall_direction = 0  
	-- if the player is clinging to the wall with a robot arm or not
	self.clinging = false
	-- if the player just did a wall jump
	self.wall_jumped = false
	-- if the player just did a double jump
	self.double_jumped = true
	-- movement input in the range [-1,1]
	self.move_input = 0
	-- the currently playing animation
	self.anim = nil
	-- keeps track of ground frames missed
	self.ground_frames_missed = 0
	-- keeps track if character is facing left
	self.facing_left = false
	-- how long the jump frame is shown
	self.jump_animation_timer = 0
	-- how long since the last step
	self.step_timer = 0
	-- if the current wall has already been touched
	self.wall_touched = false
	-- level boundaries
	self.boundaries = level_collection.boundaries[self.current_level]

	-- self.upgrade_state = get_upgrade_status(self)

	--[[
	self.anim_run = hash("player_" .. self.upgrade_state .. "_running")
	self.anim_idle = hash("player_" .. self.upgrade_state .. "_idle")
	self.anim_jump = hash("player_" .. self.upgrade_state .. "_jumping")
	self.anim_air = hash("player_" .. self.upgrade_state .. "_air")
	self.anim_wall = hash("player_" .. self.upgrade_state .. "_wall_cling")
	self.anim_doublejump = hash("player_" .. self.upgrade_state .. "_double_jumping")
	]]

	if upgrades.n_upgrades == 0 then
		self.anim_run = "player_no_upgrades_running"
		self.anim_idle = "player_no_upgrades_idle"
		self.anim_jump = "player_no_upgrades_jumping"
		self.anim_air = "player_no_upgrades_air"
		self.anim_wall = "player_no_upgrades_wall_cling"
		self.anim_doublejump = "player_no_upgrades_jumping"
	else
		self.anim_run = upgrades.anims[upgrades.n_upgrades].anim_run
		self.anim_idle = upgrades.anims[upgrades.n_upgrades].anim_idle
		self.anim_jump = upgrades.anims[upgrades.n_upgrades].anim_jump
		self.anim_air = upgrades.anims[upgrades.n_upgrades].anim_air
		self.anim_wall = upgrades.anims[upgrades.n_upgrades].anim_wall
		self.anim_doublejump = upgrades.anims[upgrades.n_upgrades].anim_doublejump
	end
	
	self.current_collection = level_collection.collection
	self.levels = level_collection.levels
	-- self.levels = {"testing_level_0:"}
end

