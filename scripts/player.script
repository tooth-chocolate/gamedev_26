-- Remove this function if not needed
-- end




local function play_animation(self, anim)
	-- only play animations which are not already playing
	if self.anim ~= anim then
		-- tell the sprite to play the animation
		sprite.play_flipbook("#sprite", anim)
		-- remember which animation is playing
		self.anim = anim
	end
end

local function update_animations(self)
	-- make sure the player character faces the right way
	if self.move_input < 0 then
		self.facing_left = true
	elseif self.move_input > 0 then
		self.facing_left = false
	end
	sprite.set_hflip("#sprite", self.facing_left)


	-- make sure the right animation is playing
	if self.jump_animation_timer > 0 then
		play_animation(self, self.anim_jump)
	elseif self.wall_contact or self.clinging then
		play_animation(self, self.anim_wall)
		if not self.wall_touched then
			msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "wall"})
			self.wall_touched = true
		end
	elseif self.ground_contact or self.ground_frames_missed < 3 then
		if self.velocity.x == 0 then
			play_animation(self, self.anim_idle)
		else
			play_animation(self, self.anim_run)
			if self.step_timer <= 0 then
				msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "step"})
				self.step_timer = step_interval
			end
		end
	elseif self.double_jumped then
		return
	else
		play_animation(self, self.anim_air)
		self.wall_touched = false
	end
end

local function calculate_dp(self, dt, acceleration, speed_diff)
	-- calculate the velocity change this frame (dv is short for delta-velocity)
	local dv = acceleration * dt
	-- check if dv exceeds the intended speed difference, clamp it in that case
	if math.abs(dv.x) > math.abs(speed_diff) then
		dv.x = speed_diff
	end
	-- save the current velocity for later use
	-- (self.velocity, which right now is the velocity used the previous frame)
	local v0 = self.velocity
	-- calculate the new velocity by adding the velocity change
	self.velocity = self.velocity + dv
	-- calculate the translation this frame by integrating the velocity
	local dp = (v0 + self.velocity) * dt * 0.5
	return dp
end

function fixed_update(self, dt)
	-- Add update code here
	-- Learn more: https://defold.com/manuals/script/
	-- Remove this function if not needed

	-- determine the target speed based on input
	local target_speed = self.move_input * max_speed

	if self.ground_frames_missed > 2 then
		target_speed = 0.6 * target_speed
	end
	-- calculate the difference between our current speed and the target speed
	local speed_diff = target_speed - self.velocity.x

	-- the complete acceleration to integrate over this frame
	if not self.ground_contact then
		self.ground_frames_missed = self.ground_frames_missed + 1
	else
		self.ground_frames_missed = 0
	end

	local acceleration = vmath.vector3(0, 0, 0)
	if self.ground_frames_missed > 1 then
		acceleration.y = gravity
	end

	if speed_diff ~= 0 then
		-- set the acceleration to work in the direction of the difference
		if speed_diff < 0 then
			acceleration.x = -move_acceleration
		else
			acceleration.x = move_acceleration
		end
		-- decrease the acceleration when air-borne to give a slower feel
		if not self.ground_contact then
			acceleration.x = air_acceleration_factor * acceleration.x
		end
	end
	-- start clinging when hitting wall with arm
	if self.wall_contact and upgrades.parts.robot_arms then
		self.clinging = true
	end

	-- stop clinging when hitting ground or pressing away from wall
	if self.ground_contact then
		self.safe_pos = go.get_position()
		self.wall_jumped = false
		self.clinging = false
	end
	if self.clinging and not self.wall_contact then
		if self.wall_jumped then
			self.clinging = false
			self.wall_jumped = false
		elseif (self.wall_direction > 0 and self.move_input > 0) or
		(self.wall_direction < 0 and self.move_input < 0) then
			self.clinging = false
		end
	end


	-- cancel gravity while clinging
	if self.clinging and upgrades.parts.robot_arms then
		acceleration.y = 0

	end
	local dp = calculate_dp(self, dt, acceleration, speed_diff)
	-- apply it to the player character
	local target_position = go.get_position() + dp
	target_position.x = math.max(target_position.x, self.boundaries.left)
	target_position.x = math.min(target_position.x, self.boundaries.right)
	go.set_position(target_position)

	if self.jump_animation_timer > 0 then
		self.jump_animation_timer = self.jump_animation_timer - dt
	end
	if self.step_timer > 0 then
		self.step_timer = self.step_timer - dt
	end
	update_animations(self)

	-- reset volatile state
	self.correction = vmath.vector3()
	self.ground_contact = false
	self.wall_contact = false
	self.move_input = 0

end

