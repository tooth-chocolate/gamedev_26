local function handle_obstacle_contact(self, normal, distance)
	if distance > 0 then
		-- project the correction vector onto the contact normal
		-- (the correction vector is the 0-vector for the first contact point)
		local proj = vmath.project(self.correction, normal * distance)
		-- calculate the compensation we need to make for this contact point
		if proj < 1 then
			local comp = (distance - distance * proj) * normal
			-- add it to the correction vector
			self.correction = self.correction + comp
			-- apply the compensation to the player character
			go.set_position(go.get_position() + comp)
		end
		-- check if the normal points enough up to consider the player standing on the ground
		-- (0.7 is roughly equal to 45 degrees deviation from pure vertical direction)
		if normal.y > 0.7 then
			self.ground_contact = true
			self.jump_count = 0
			self.velocity.y = 0
			self.double_jumped = false
		elseif math.abs(normal.x) > 0.7 then
			self.wall_contact = true
			self.wall_direction = normal.x > 0 and 1 or -1
			self.wall_jumped = false
			self.double_jumped = false
			self.jump_count = 0
			self.velocity.x = 0
			if upgrades.parts.robot_arms then
				self.velocity.y = 0  -- stop sliding down
			end
		elseif normal.y < -0.7 then
			self.velocity.y = 0
		end
	end
end

local function death_handler(self)
	msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "death"})
	if upgrades.parts.robot_torso then
		msg.post(self.controller, "player_died", {last_safe = self.safe_pos})
	else
		msg.post(self.controller, "player_died")
		msg.post(self.current_collection .."/rescue_board#rescue", "add_rescues", {rescue = 1})
	end

	-- print(self.levels[self.current_level] .."/test_camera#test_camera")
	msg.post(self.levels[self.current_level] .."/test_camera#test_camera", "stop")
	go.delete()

end

function on_message(self, message_id, message, sender)
	-- Add message-handling code here
	-- Learn more: https://defold.com/manuals/message-passing/
	-- Remove this function if not needed

	-- check if we received a contact point message
	if message_id == msg_contact_point_response then
		-- check that the object is something we consider an obstacle
		if message.group == group_obstacle then
			handle_obstacle_contact(self, message.normal, message.distance)
		end
	end

	if message_id == trigger then 
		if message.other_group == death then
			death_handler(self)
		elseif message.other_group == goal then
			msg.post(self.current_collection .."/loader#game_loader", "level_complete")
			go.delete()
			-- print("GOAL")
		end
	end
end

local function jump(self)
	local max_jumps = 1
	if upgrades.parts.robot_legs then
		max_jumps = 2
	end
	-- only allow jump from ground
	if self.ground_contact or self.ground_frames_missed < 3 then
		self.velocity.y = jump_takeoff_speed
		-- play animation
		self.jump_animation_timer = 0.2
		play_animation(self, self.anim_jump)
		msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "jump"})
		self.jump_count = 1
	elseif self.wall_contact or self.clinging then
		self.velocity.y = jump_takeoff_speed
		self.velocity.x = self.wall_direction * max_speed
		self.clinging = false
		self.wall_jumped = true
		self.jump_count = 1
	elseif self.jump_count < max_jumps and self.ground_frames_missed < 3 then
		self.velocity.y = jump_takeoff_speed
		-- play animation
		self.jump_animation_timer = 0.2
		play_animation(self, self.anim_jump)
		msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "jump"})
		self.jump_count = self.jump_count + 1
		-- allow jumping in air with robot legs
	elseif self.jump_count < max_jumps and max_jumps == 2 then
		self.velocity.y = jump_takeoff_speed
		-- play animation
		play_animation(self, self.anim_doublejump)
		msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_sfx", {sfx = "jump"})
		self.double_jumped = true
		if self.jump_count == 0 then
			self.jump_count = self.jump_count + 2
		else 
			self.jump_count = self.jump_count + 1
		end
	end
end

local function abort_jump(self)
	-- cut the jump short if we are still going up
	if self.velocity.y > 0 then
		-- scale down the upwards speed
		self.velocity.y = self.velocity.y * 0.5
	end
end

function on_input(self, action_id, action)
	-- Add input-handling code here. The game object this script is attached to
	-- must have acquired input focus:
	--
	-- msg.post(".", "acquire_input_focus")
	--
	-- All mapped input bindings will be received. Mouse and touch input will
	-- be received regardless of where on the screen it happened.
	-- Learn more: https://defold.com/manuals/input/
	-- Remove this function if not needed
	if action_id == input_left then
		self.move_input = -action.value
	elseif action_id == input_right then
		self.move_input = action.value
	elseif action_id == input_jump then
		if action.pressed then
			jump(self)
		elseif action.released then
			abort_jump(self)
		end
	end

	if action_id == cheat and action.pressed then
		msg.post(self.current_collection .."/loader#game_loader", "level_complete")
		go.delete()
		--print("GOAL")
	end
end

