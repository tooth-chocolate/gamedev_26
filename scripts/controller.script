local upgrades = require "modules.upgrade_state"
local level_collection = require "modules.level_collection"

local menu_spawn = hash("menu_spawn")
local normal_spawn = hash("normal_spawn")
local prompt_spawn = hash("prompt_spawn")
local function get_track_name(self, upgrades)
	if self.current_level == 3 then
		return "cave"
	elseif upgrades.parts.robot_torso then
		return "level_robot"
	elseif upgrades.parts.robot_arms then
		return "level_halfrobot"
	else
		return "level_human"
	end
end

local function spawn_player(self, spawn_location)
	--[[if self.player then
		go.delete(self.player)
	end]]
	self.player = factory.create("#player_factory", spawn_location, nil, {controller = go.get_id(), current_level = self.current_level})
	msg.post("/test_camera#test_camera", "track", {
		tracked = msg.url(nil, self.player, nil)
	})
	
	msg.post(self.current_collection .. "/sound_manager#sound_manager", "play_music", {track = get_track_name(self, upgrades)})
end
		
function init(self)
	-- Add initialization code here
	-- Learn more: https://defold.com/manuals/script/
	-- Remove this function if not needed
	self.init_spawn = vmath.vector3(100, 41, 0.1)
	self.rescue_thresholds = {5, 4, 3 ,7, 2}
	self.rescues = 0
	self.current_level = 1
	self.current_collection = level_collection.collection
	self.level_prompted = false
	-- self.upgrade_prompted = {false, false, false, false, false}
	self.part = 1
	self.current_spawn_location = self.init_spawn
	

	self.current_rescue_threshold = self.rescue_thresholds[upgrades.n_upgrades+1]
	
end

