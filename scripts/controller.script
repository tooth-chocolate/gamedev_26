--[[local function upgrade_ui_caller(self)
	if self.rescues > self.rescue_threshold then
		msg.post(self.current_collection .."/upgrade_menu#upgrade_menu", "adapt_menu")
		-- msg.post("main_testing:/loader#game_loader", "release_input_focus")
		msg.post(self.current_collection .."/upgrade_menu#upgrade_menu", "enable")
	end
end]]

local function upgrade_ui_caller(self)
	--print(self.prompted)
	--print(self.rescues)
	--print(self.current_rescue_threshold)
	if self.rescues > self.current_rescue_threshold and not self.level_prompted and upgrades.n_upgrades < self.current_level then
		print("upgrade_ui_called")
		local path = self.current_collection .."/upgrade_prompt#upgrade_prompt"
		msg.post(path, "enable")
		msg.post(path, "prompt")
	else
		msg.post(".", "normal_spawn")
	end
end

local function respawn_handler(self, message)
	self.rescues = self.rescues + 1
	if next(message) ~= nil then
		self.current_spawn_location = message.last_safe
	end
	upgrade_ui_caller(self)
	-- timer.delay(1.0, false, function() spawn_player(self, self.current_spawn_location) end)
end

function on_message(self, message_id, message, sender)
	-- Add message-handling code here
	-- Learn more: https://defold.com/manuals/message-passing/
	-- Remove this function if not needed
	
	if message_id == hash("player_died") then
		-- local spawn_location = vmath.vector3(40, 40, 1)
		-- timer.delay(1.0, false, function() spawn_player(self, spawn_location) end)
		respawn_handler(self, message)
	end

	if message_id == hash("current_level_configure") then
		self.current_level = message.current_level
		spawn_player(self, self.init_spawn)
		self.prompted = false
		-- self.rescue_threshold = message.rescue_threshold
		--[[msg.post("/test_camera#test_camera", "track", {
			tracked = msg.url(nil, self.player, nil)
		})
		]]
	end

	--[[if message_id == hash("spawn") then
		if message.n_upgrades > self.n_upgrades then
			self.rescues = 0
			self.n_upgrades = message.n_upgrades
			
			if self.n_upgrades < self.current_level then
				self.current_rescue_threshold = self.rescue_thresholds[self.n_upgrades + 1]
			end
		end
		self.prompted = message.prompted
		timer.delay(1.0, false, function() spawn_player(self, self.current_spawn_location) end)
	end
	]]

	if message_id == normal_spawn then
		spawn_player(self, self.current_spawn_location)
	end

	if message_id == prompt_spawn then
		print("prompt spawn")
		if message.upgraded then
			self.rescues = 0
			if upgrades.n_upgrades < self.current_level then
				self.current_rescue_threshold = self.rescue_thresholds[upgrades.n_upgrades + 1]
			end
		end
		for i = 1, 5 do
			if not upgrades.prompted[i] then
				self.part = i
			end
		end
		msg.post(self.current_collection .."/upgrade_menu#upgrade_menu", "upgrade_menu", {part = self.part})
		timer.delay(1.0, false, function() spawn_player(self, self.current_spawn_location) end)
	end

	if message_id == menu_spawn then
		go.delete(self.player)
		timer.delay(1.0, false, function() spawn_player(self, self.current_spawn_location) end)
	end

	--[[_if message_id == hash("spawn") then
		timer.delay(1.0, false, function() spawn_player(self, self.current_spawn_location) end)
	end]]
end

