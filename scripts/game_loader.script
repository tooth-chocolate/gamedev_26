-- handles what happens if you complete a level. current level gets disabled and next level get loaded.
local function level_completion_handler(self, message_id)
	if self.cur_index == self.n_levels then
		-- disable level
		msg.post("#" ..self.current_level, "disable")
		msg.post("#" ..self.current_level, "unload")
		-- disable other UI elements
		msg.post("/rescue_board#rescue", "disable")
		msg.post("/upgrade_menu_button#upgrade_menu_button", "disable")
		msg.post("/endings#ending_gui", "enable")
		msg.post("/endings#ending_gui", "start")
		timer.delay(2.0, false, function()
			msg.post("/sound_manager#sound_manager", "play_music", {track = "ending"})
		end)
	else
		local next_level = self.levels[self.cur_index + 1]
		msg.post("#" ..self.current_level, "disable")
		msg.post("#" ..self.current_level, "unload")
		msg.post("#" ..next_level, "load")
		self.cur_index = self.cur_index + 1
		self.current_level = next_level
	end
end

function on_message(self, message_id, message, sender)
	-- Add message-handling code here
	-- Learn more: https://defold.com/manuals/message-passing/
	-- Remove this function if not needed
	if message_id == level_complete then
		level_completion_handler(self, message_id)
	end

	if message_id == proxy_loaded then
		local controller = msg.url(sender.fragment, "/game_controller", "controller")
		-- print(controller)
		-- print("controller url: ", controller)
		msg.post(sender, "enable")
		-- msg.post(controller, "current_level_configure", {current_level = self.cur_index, rescue_threshold = self.rescue_thresholds[self.cur_index]})
		msg.post(controller, "current_level_configure", {current_level = self.cur_index})
		msg.post("/upgrade_handler#upgrade_handler", "current_level_configure", {current_level = self.cur_index})
	end

	if message_id == start_game then
		self.cur_index = 1
		self.current_level = self.levels[1]
		msg.post("#" ..self.current_level, "load")
	end
end

