local level_collection = require "modules.level_collection"
local level_complete = hash("level_complete")
local proxy_loaded = hash("proxy_loaded")
local start_game = hash("start_game")

-- arms: 5 rescues
-- legs: 4 rescues
-- eyes: 3 rescues
-- torso: 7 rescues
-- brain: 2 rescues


function init(self)
	-- Add initialization code here
	-- Learn more: https://defold.com/manuals/script/
	-- Remove this function if not needed
	--self.levels = {"#testing_level_3"}
	self.cur_collection = level_collection.collection
	-- self.levels = {"#testing_level_0", "#testing_level_1", "#testing_level_2", "#testing_level_3", "#testing_level_4", "#testing_level_5"}
	self.levels = level_collection.levels[self.cur_collection]
	self.current_level = self.levels[1]
	self.cur_index = 1
	self.n_levels = #self.levels
	-- self.rescue_thresholds = {5, 4, 3, 7, 2}
	msg.post("/upgrade_menu_button#upgrade_menu_button", "disable")
	msg.post(".", "acquire_input_focus")
end

